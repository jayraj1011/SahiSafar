# Server
PORT=3000
NODE_ENV=development

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/cityyatra
# For MongoDB Atlas (cloud): mongodb+srv://username:password@cluster.mongodb.net/cityyatra

# Email Configuration (Gmail example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=City Yatra <your_email@gmail.com>

# Admin Notification Email
ADMIN_EMAIL=admin@cityyatra.com

# Business Info
BUSINESS_PHONE=+91-9876543210
BUSINESS_NAME=City Yatra
